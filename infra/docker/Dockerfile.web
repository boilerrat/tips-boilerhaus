# ============================================================
# Dockerfile — apps/web
# Multi-stage build producing a minimal standalone Next.js image.
# Designed for deployment behind Traefik on boilerhaus.org.
# ============================================================

# --- Stage 1: dependency install ---
FROM node:20-alpine AS deps
RUN apk add --no-cache libc6-compat

# Enable pnpm via corepack
RUN corepack enable && corepack prepare pnpm@9.0.0 --activate

WORKDIR /app

# Copy workspace manifest files first to maximise layer cache reuse
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY apps/web/package.json ./apps/web/package.json
COPY packages/shared/package.json ./packages/shared/package.json

RUN pnpm install --frozen-lockfile

# --- Stage 2: build ---
FROM node:20-alpine AS builder
RUN corepack enable && corepack prepare pnpm@9.0.0 --activate

WORKDIR /app

# Inherit installed deps
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules

# Copy full source
COPY . .

# Build-time env vars must be provided here via --build-arg or docker-compose args.
# NEXT_PUBLIC_* vars are baked into the bundle at build time.
ARG NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID
ARG NEXT_PUBLIC_DEFAULT_CHAIN_ID=84532
ARG NEXT_PUBLIC_REGISTRY_CONTRACT_ADDRESS
ARG NEXT_PUBLIC_BASE_RPC_URL
ARG NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL

ENV NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=$NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID
ENV NEXT_PUBLIC_DEFAULT_CHAIN_ID=$NEXT_PUBLIC_DEFAULT_CHAIN_ID
ENV NEXT_PUBLIC_REGISTRY_CONTRACT_ADDRESS=$NEXT_PUBLIC_REGISTRY_CONTRACT_ADDRESS
ENV NEXT_PUBLIC_BASE_RPC_URL=$NEXT_PUBLIC_BASE_RPC_URL
ENV NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=$NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL

WORKDIR /app/apps/web
RUN pnpm build

# --- Stage 3: runtime ---
# Uses the standalone output — no node_modules, minimal footprint
FROM node:20-alpine AS runner

WORKDIR /app

# Non-root user for security
RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

# Copy only what the standalone server needs
COPY --from=builder /app/apps/web/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./.next/static

USER nextjs

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"
ENV NODE_ENV=production

# Health check — Traefik will poll this before routing traffic
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD wget -qO- http://localhost:3000/ || exit 1

CMD ["node", "server.js"]
