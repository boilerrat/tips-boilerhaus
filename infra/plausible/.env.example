BASE_URL=https://plausible.boilerhaus.org
SECRET_KEY_BASE=replace_with_openssl_rand_base64_48
HTTP_PORT=8000

# First deploy: leave registration open long enough to create the admin user.
# After that, set to invite_only or true and redeploy.
DISABLE_REGISTRATION=false
ENABLE_EMAIL_VERIFICATION=false

# Optional. If omitted, Plausible derives one from SECRET_KEY_BASE.
TOTP_VAULT_KEY=

# Optional email settings. Leave blank unless you want password reset / reports.
MAILER_ADAPTER=
MAILER_EMAIL=
MAILER_NAME=
SMTP_HOST_ADDR=
SMTP_HOST_PORT=
SMTP_USER_NAME=
SMTP_USER_PWD=
SMTP_HOST_SSL_ENABLED=
