# ============================================================
# tips-boilerhaus — environment variable reference
# Copy to .env.local for local dev. Never commit actual values.
# ============================================================

# --- Next.js app (apps/web) ---

# Privy app ID (https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=

# Primary chain ID (8453 = Base, 84532 = Base Sepolia)
NEXT_PUBLIC_DEFAULT_CHAIN_ID=84532

# Deployed CreatorRegistry contract address (set after contract deploy)
NEXT_PUBLIC_REGISTRY_CONTRACT_ADDRESS=

# RPC URLs — Alchemy or Infura recommended
NEXT_PUBLIC_BASE_RPC_URL=
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=

# --- IPFS / Pinata (creator metadata uploads) ---

# Pinata JWT token (https://app.pinata.cloud/developers/api-keys)
# Server-side only — never exposed to the browser
PINATA_JWT=

# Pinata dedicated gateway URL (e.g. https://mygateway.mypinata.cloud)
# Used client-side to resolve IPFS content
NEXT_PUBLIC_PINATA_GATEWAY_URL=

# --- Contracts (packages/contracts) ---

# Deployer private key — NEVER commit, only inject at deploy time
DEPLOYER_PRIVATE_KEY=

# Etherscan/Basescan API key for contract verification
BASESCAN_API_KEY=
