# ============================================================
# tips-boilerhaus — environment variable reference
# Copy to .env.local for local dev. Never commit actual values.
# ============================================================

# --- Next.js app (apps/web) ---

# Privy app ID (https://dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=

# Primary chain ID (8453 = Base, 84532 = Base Sepolia)
NEXT_PUBLIC_DEFAULT_CHAIN_ID=84532

# Deployed CreatorRegistry contract address (set after contract deploy)
# Base mainnet: 0x5fb3bBEE3AB0B21c21126C66d9bba424F2ff44ef
# Base Sepolia: 0xd9e883c4a8340fF4138d4fE229B05445fAaE0971
NEXT_PUBLIC_REGISTRY_CONTRACT_ADDRESS=

# Deployed SubscriptionManager contract address (set after contract deploy)
# Base mainnet: 0x1F81679cdcb90dF123a2938192ee114086170E66
# Base Sepolia: 0xD77A14d390F6BC08F6aB720787c046F8b2850114
NEXT_PUBLIC_SUBSCRIPTION_MANAGER_ADDRESS=

# RPC URLs — Alchemy or Infura recommended
NEXT_PUBLIC_BASE_RPC_URL=
NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=

# --- IPFS / Pinata (creator metadata uploads) ---

# Pinata JWT token (https://app.pinata.cloud/developers/api-keys)
# Server-side only — never exposed to the browser
PINATA_JWT=

# Pinata dedicated gateway URL (e.g. https://mygateway.mypinata.cloud)
# Used client-side to resolve IPFS content
NEXT_PUBLIC_PINATA_GATEWAY_URL=

# --- Coinbase Onramp (fiat-to-crypto funding) ---

# CDP API key name (e.g. "organizations/xxx/apiKeys/yyy")
# Create at portal.cdp.coinbase.com → API Keys
# Server-side only — never exposed to the browser
COINBASE_ONRAMP_API_KEY=

# CDP API key secret (ES256 EC private key in PEM format)
# Store with literal \n for newlines in .env files
# Server-side only — never exposed to the browser
COINBASE_ONRAMP_API_SECRET=

# --- Subscription Keeper (packages/keeper) ---

# Private key for the keeper wallet (funds processRenewal() gas)
# Must be a 0x-prefixed 32-byte hex string
# Mainnet keeper address: 0x10D325DD63e3B9F02CbAAC1F00d3eA9933Caafb7
# NEVER commit — inject at deploy time
KEEPER_PRIVATE_KEY=

# RPC URL for the keeper
# Mainnet: use a Base mainnet RPC (Alchemy/Infura)
# Testnet: defaults to Base Sepolia RPC
KEEPER_RPC_URL=

# Sweep interval in ms (default: 60000 = 1 minute)
KEEPER_INTERVAL_MS=60000

# --- Contracts (packages/contracts) ---

# Deployer private key — NEVER commit, only inject at deploy time
DEPLOYER_PRIVATE_KEY=

# Fee recipient address for protocol fees (set at deploy, immutable)
# Mainnet: 0xc0903d14641084CE3Efa448a3e832e9d97A02CCf (Safe multisig)
# Defaults to deployer address if not set
FEE_RECIPIENT=

# Protocol fee in basis points (set at deploy, immutable)
# 100 = 1%, max 500 = 5%. Defaults to 0 if not set.
FEE_BPS=

# Etherscan/Basescan API key for contract verification
BASESCAN_API_KEY=
